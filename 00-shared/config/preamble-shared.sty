% Set counters to be reset when section counter is incremented
\counterwithin{table}{section}
\counterwithin{figure}{section}
% Set period (by default ':') for number/caption separator
\usepackage[font={bf}]{caption}
\captionsetup{labelsep=period}
% Set dash for section/counter separator
\renewcommand{\thefigure}{\thesection{}-\arabic{figure}}
\renewcommand{\thetable}{\thesection{}-\arabic{table}}

% Define macro for including figure and overlaying text, see
% https://tex.stackexchange.com/questions/117358/newcommand-argument-confusion
% https://latexdraw.com/how-to-annotate-an-image-in-latex/
\newcommand{\figuretext}[3][]{%
  \begin{tikzpicture}

    % Include the image in a node
    \node[anchor=south west] (image) at (0,0) {#2};
    
    % Create scope with normalized axes
    \begin{scope}[
      x={($0.1*(image.south east)$)},
      y={($0.1*(image.north west)$)}]

      % Use "grid=TRUE" to enable grid for easy positioning of text
      \ifthenelse{\equal{#1}{grid=TRUE}}{%
        % Grid
        \draw[lightgray,step=1] (image.south west) grid (image.north east);
        % Axes' labels
        \foreach \x in {0,1,...,10} { \node [below] at (\x,0) {\x}; }
        \foreach \y in {0,1,...,10} { \node [left] at (0,\y) {\y}; }
      }{}

      % Add/update text if needed
      #3%
    \end{scope}
  \end{tikzpicture}%
}


