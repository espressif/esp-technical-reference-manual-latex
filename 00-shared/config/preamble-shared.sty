% For absolute positioning of text and graphics on the page
\usepackage{tikz}
\usetikzlibrary{calc}

% Mark groups of table cells with rectangles, borrowed from
% https://tex.stackexchange.com/questions/4850/highlighting-table-cells
\usetikzlibrary{fit,shapes.misc}
%\usepackage{hhline}

% Mark top left
\newcommand\mtl[2][none]{%
    \tikz[overlay,remember picture] 
        \node (marker-#2-a) at (0,0.9ex) {};%
}

% Mark bottom right
\newcommand\mbr[2][none]{%
    \tikz[overlay,remember picture] 
        \node (marker-#2-b) at (0.2ex,0.3ex) {};%
    \tikz[overlay,remember picture,thick,inner sep=5pt]
        \node[draw,
              blend mode=darken,
              rectangle,
              rounded corners,
              fill=#1,
              fit=(marker-#2-a.center) (marker-#2-b.center)] {};%
    \tikz[overlay,remember picture] 
        %See https://tex.stackexchange.com/questions/544665/latex-tikz-position-text-relative-in-rectangle
    \path 
        let
          \p{mtl} = (marker-#2-a), \p{mbr} = (marker-#2-b)
        in
          [x=\x{mbr}, y=\y{mtl}, xshift=1em, yshift=1em]
          node[rounded corners,inner sep=2pt,fill=white,opacity=0.8,text opacity=1] at (1, 1) {\footnotesize{\textbf{#2}}};%
}

% If frame covers text on the right, push the right side using spacing macros. Example: & SPID\quad\mbr{5c} &
% https://tex.stackexchange.com/questions/41476/lengths-and-when-to-use-them


