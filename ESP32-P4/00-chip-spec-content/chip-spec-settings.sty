\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}

% Header
\fancypagestyle{plain}{%
  \fancyhead{}%
  \fancyhead[R]{\Navigation}  
  \fancyhead[L]{%
    \nouppercase{%
      \ %
      \normalsize\leftmark
    }%
  }%
}
\pagestyle{plain}

% Footer

\iftagged{ESP32-P4-latest}{
  \lfoot{\GetTranslation{company}}
  %\cfoot{\thepage \\ \href{\feedbacklink}{\small{Submit Documentation Feedback}}}
  \cfoot{\thepage \\ \href{\feedbacklink}{\small{\GetTranslation{sendfeedback}}}}
  \rfoot{\chipname{} TRM \\ \iflabelexists{tab:release-status}
  % Remove "CONFIDENTIAL" upon the first release
  {\hyperref[tab:release-status]{PRELIMINARY}}
  {PRELIMINARY}}
}{
    \lfoot{\GetTranslation{company}}
    %\cfoot{\thepage \\ \href{\feedbacklink}{\small{Submit Documentation Feedback}}}
    \cfoot{\thepage \\ \href{\feedbacklink}{\small{\GetTranslation{sendfeedback}}}}
    \rfoot{\chipname{} \GetTranslation{chiprevision} TRM \\ \iflabelexists{tab:release-status}
    % Remove "CONFIDENTIAL" upon the first release
    {\hyperref[tab:release-status]{PRELIMINARY}}
    {PRELIMINARY}}
}


