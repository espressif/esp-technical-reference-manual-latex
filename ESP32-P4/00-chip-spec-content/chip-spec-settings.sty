%%%%%%%%%%%%%%%%%%%%%
%%% P5: Watermark %%%
%%%%%%%%%%%%%%%%%%%%%
\newif\ifwatermark

% Add watermark?
% 'YES' - uncomment line below; 'NO' - comment out

\iftagged{ESP32-P4-latest}{
  \watermarktrue
}{
    \watermarktrue
}

% Include content if a label is defined
% https://tex.stackexchange.com/questions/111311/how-to-make-a-conditional-reference-to-a-text-label
\newcommand{\iflabelexists}[3]{\ifcsundef{r@#1}{#3}{#2}}

\ifwatermark
    % Add watermark to title page
    \definecolor{watermark}{rgb}{0.83, 0.83, 0.83}
    \usepackage[firstpageonly=true]{draftwatermark}
    \SetWatermarkAngle{45}
    \SetWatermarkColor{watermark}
    \SetWatermarkFontSize{3.5cm}
    % Update watermark text if needed; Remove "CONFIDENTIAL" upon the first release
    \SetWatermarkText{PRELIMINARY}

\fi %\ifwatermark


