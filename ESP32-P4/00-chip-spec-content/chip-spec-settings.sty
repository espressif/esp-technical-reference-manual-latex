% Doc: LaTeX Template for TRMs by Espressif
% P?: marks a preamble setting (or important notice) number

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{chip-spec-settings}[LaTeX package defining a chip specific preamble for TRM]


%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% P1: Define Variables %%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% If using a variable in text, follow it with {},
% otherwise a following space will be deleted by LaTeX
% Example: \chipname{} is a new product from Espressif.

% >>> Name of chip <<<
\newcommand\chipname{ESP32-P4}


% Portion of link to filter certificates for your product(s),
% For details, see Module Datasheet Instructions > Section "Filter Certificates"
\newcommand\productcertificates{?keys=&field_product_value\%5B\%5D=\chipseries}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% P2: Doc Version Parameters %%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% >>> Document version number <<<

\iftagged{ESP32-P4-latest}{
  \newcommand\docversion{0.5}
}{
    \newcommand\docversion{0.3}
}

% >>> Chip revision number <<<
% English
\newcommand\chiprevisionEN{%
    \untagged{ESP32-P4-latest}{Chip Revision v1.3}%
}%

% Chinese
% >>> Text before chip revision number <<<
\newcommand\chiprevisionCN{%
    \untagged{ESP32-P4-latest}{芯片版本 v1.3}%
}%

% >>> Text before doc version number <<<
% English
\newcommand\docversionprefixEN{%
    \tagged{ESP32-P4-latest}{Pre-release v}%
    \untagged{ESP32-P4-latest}{Pre-release v}%
}%
% Chinese
\newcommand\docversionprefixCN{%
    \tagged{ESP32-P4-latest}{预发布 v}%
    \untagged{ESP32-P4-latest}{预发布 v}%
}%

