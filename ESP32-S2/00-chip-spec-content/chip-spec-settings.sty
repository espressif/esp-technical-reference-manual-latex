%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% If using a variable in text, follow it with {},
% otherwise a following space will be deleted by LaTeX
% Example: \chipname{} is a new product from Espressif.

% >>> Name of chip <<<
\newcommand\chipname{ESP32-S2}

% Portion of link to filter certificates for your product(s),
% For details, see Module Datasheet Instructions > Section "Filter Certificates"
\newcommand\productcertificates{?keys=&field_product_value\%5B\%5D=\chipseries}


